          "data_type": "varchar",
          "tags": [],
          "meta": {}
        },
        "orders_count_7d": {
          "name": "orders_count_7d",
          "description": "Number of orders in the trailing 7 days",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "used_by": ["churn_model_v2", "ltv_model_v3"]
            }
          }
        },
        "is_repeat_customer": {
          "name": "is_repeat_customer",
          "description": "Has the customer ordered more than once",
          "data_type": "boolean",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "used_by": ["churn_model_v2"]
            }
          }
        },
        "total_value_usd": {
          "name": "total_value_usd",
