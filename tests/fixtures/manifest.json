          "data_type": "DECIMAL(10, 2)",
          "tags": [],
          "meta": {}
        },
        "preferred_category": {
          "name": "preferred_category",
          "description": "Most-purchased product category",
          "data_type": "varchar",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "feature_type": "categorical"
            }
          }
        },
        "_loaded_at": {
          "name": "_loaded_at",
          "description": "Internal load timestamp",
          "data_type": "timestamp",
          "tags": [],
          "meta": {}
        },
        "debug_score": {
