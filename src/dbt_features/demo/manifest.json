    "model.demo_features.customer_features_daily": {
      "name": "customer_features_daily",
      "unique_id": "model.demo_features.customer_features_daily",
      "resource_type": "model",
      "package_name": "demo_features",
      "path": "features/customer_features_daily.sql",
      "original_file_path": "models/features/customer_features_daily.sql",
      "description": "Daily booking and engagement features per customer. Anchor table for most ranking models.",
      "schema": "analytics",
      "database": "warehouse",
      "config": {"materialized": "table", "meta": {}},
      "meta": {
        "feature_catalog": {
          "is_feature_table": true,
          "entity": "customer_id",
          "grain": ["feature_date", "customer_id"],
          "timestamp_column": "feature_date",
          "freshness": {
            "warn_after": {"count": 36, "period": "hour"},
            "error_after": {"count": 48, "period": "hour"}
          },
          "owner": "growth-team@example.com",
          "tags": ["customer", "daily"]
        }
      },
      "depends_on": {"nodes": ["model.demo_features.stg_orders", "model.demo_features.stg_sessions"]},
      "columns": {
        "feature_date": {
          "name": "feature_date",
          "description": "Date the features are computed for",
          "data_type": "date",
          "tags": [],
          "meta": {}
        },
        "customer_id": {
          "name": "customer_id",
          "description": "Customer identifier",
          "data_type": "varchar",
          "tags": [],
          "meta": {}
        },
        "orders_count_7d": {
          "name": "orders_count_7d",
          "description": "Number of orders placed in the trailing 7 days",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "used_by": ["churn_model_v2", "ltv_model_v3", "ranking_model_v4"]
            }
          }
        },
        "orders_count_30d": {
          "name": "orders_count_30d",
          "description": "Number of orders placed in the trailing 30 days",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "definition_version": 2,
              "used_by": ["churn_model_v2", "ltv_model_v3"]
            }
          }
        },
        "orders_count_legacy": {
          "name": "orders_count_legacy",
          "description": "Legacy lifetime count, kept for the now-retired ranking_model_v3",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "lifecycle": "deprecated",
              "replacement": "orders_count_30d"
            }
          }
        },
        "sessions_count_7d": {
          "name": "sessions_count_7d",
          "description": "Distinct web sessions in the trailing 7 days",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "used_by": ["churn_model_v2"]
            }
          }
        },
        "is_repeat_customer": {
          "name": "is_repeat_customer",
          "description": "Has the customer ordered more than once",
          "data_type": "boolean",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "used_by": ["churn_model_v2"]
            }
          }
        },
        "preferred_category": {
          "name": "preferred_category",
          "description": "Most-ordered product category in the trailing 30 days",
          "data_type": "varchar",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "feature_type": "categorical",
              "null_behavior": "propagate",
              "used_by": ["ranking_model_v4"]
            }
          }
        }
      }
    },
    "model.demo_features.customer_features_lifetime": {
      "name": "customer_features_lifetime",
