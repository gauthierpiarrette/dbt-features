      "depends_on": {"nodes": ["model.demo_features.customer_features_daily"]},
      "columns": {
        "customer_id": {
          "name": "customer_id",
          "description": "Customer identifier",
          "data_type": "varchar",
          "tags": [],
          "meta": {}
        },
        "lifetime_order_count": {
          "name": "lifetime_order_count",
          "description": "All-time order count for this customer",
          "data_type": "integer",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "zero",
              "used_by": ["ltv_model_v3"]
            }
          }
        },
        "lifetime_order_value_usd": {
          "name": "lifetime_order_value_usd",
