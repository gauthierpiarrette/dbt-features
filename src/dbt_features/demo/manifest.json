            "feature_catalog": {
              "null_behavior": "zero",
              "used_by": ["ltv_model_v3"]
            }
          }
        },
        "first_order_date": {
          "name": "first_order_date",
          "description": "Date of the customer's first order",
          "data_type": "date",
          "tags": [],
          "meta": {
            "feature_catalog": {
              "null_behavior": "propagate"
            }
          }
        }
      }
    },
    "model.demo_features.store_features_hourly": {
      "name": "store_features_hourly",
